# ── auth_tenant / admin ─────────────────────────────────────────────
msgid "Personal info"
msgstr "Личные данные"

msgid "Permissions"
msgstr "Права доступа"

msgid "Meta"
msgstr "Метаданные"

# ── auth_tenant / models (choices) ──────────────────────────────────
msgid "Admin"
msgstr "Администратор"

msgid "Manager"
msgstr "Менеджер"

msgid "Seller"
msgstr "Продавец"

msgid "Male"
msgstr "Мужской"

msgid "Female"
msgstr "Женский"

# ── auth_tenant / serializers + views ───────────────────────────────
msgid "Passport series must match AB1234567 format."
msgstr "Серия паспорта должна соответствовать формату AB1234567."

#, python-format
msgid "Phone must match %(example)s format."
msgstr "Телефон должен соответствовать формату %(example)s."

msgid "A user with this phone already exists."
msgstr "Пользователь с таким телефоном уже существует."

msgid "A user with this email already exists."
msgstr "Пользователь с таким email уже существует."

msgid "Passwords do not match."
msgstr "Пароли не совпадают."

msgid "User not found in your tenant."
msgstr "Пользователь не найден в вашей организации."

#, python-format
msgid "Unsupported permission: %(permission)s"
msgstr "Неподдерживаемое разрешение: %(permission)s"

msgid "You cannot delete your own account."
msgstr "Нельзя удалить свою учётную запись."

msgid "Role not found."
msgstr "Роль не найдена."

# ── clients / models (communication language) ───────────────────────
msgid "Uzbek"
msgstr "Узбекский"

msgid "Russian"
msgstr "Русский"

msgid "English"
msgstr "Английский"

# ── clients / serializers + views ───────────────────────────────────
msgid "At least one phone number is required."
msgstr "Требуется минимум один телефон."

#, python-format
msgid "Unsupported phone format: %(phones)s. Use one of: %(examples)s."
msgstr "Недопустимый формат телефона: %(phones)s. Используйте один из: %(examples)s."

msgid "Client with this phone number already exists."
msgstr "Клиент с таким номером уже существует."

msgid "Name is required."
msgstr "Укажите имя."

#, python-format
msgid "Phone must match one of: %(examples)s."
msgstr "Телефон должен соответствовать одному из форматов: %(examples)s."

msgid "Excel import requires openpyxl package on backend."
msgstr "Для импорта из Excel требуется пакет openpyxl на бэкенде."

msgid "Invalid Excel file."
msgstr "Некорректный Excel-файл."

msgid "Excel file is empty."
msgstr "Excel-файл пустой."

msgid "No client rows found in Excel."
msgstr "В Excel-файле не найдено ни одного клиента."

#, python-format
msgid "Row %(idx)d: name is required."
msgstr "Строка %(idx)d: укажите имя."

#, python-format
msgid "Row %(idx)d: phone is required."
msgstr "Строка %(idx)d: укажите телефон."

#, python-format
msgid "Duplicate phones in file: %(phones)s."
msgstr "Дубликаты телефонов в файле: %(phones)s."

#, python-format
msgid "Phones already exist: %(phones)s."
msgstr "Телефоны уже существуют: %(phones)s."

# ── debts / models + serializers + views ────────────────────────────
msgid "Active"
msgstr "Активный"

msgid "Closed"
msgstr "Закрыт"

msgid "Amount must be greater than zero."
msgstr "Сумма должна быть больше нуля."

msgid "Debt is already closed."
msgstr "Долг уже закрыт."

#, python-format
msgid "Amount exceeds remaining debt of %(remaining)s."
msgstr "Сумма превышает остаток долга: %(remaining)s."

# ── products / serializers + views ──────────────────────────────────
msgid "Purchase price must be >= 0."
msgstr "Закупочная цена должна быть >= 0."

msgid "Sale price must be >= 0."
msgstr "Цена продажи должна быть >= 0."

msgid "Stock must be >= 0."
msgstr "Остаток должен быть >= 0."

msgid "Quantity must not be zero."
msgstr "Количество не может быть равно нулю."

msgid "Stock value must be >= 0."
msgstr "Значение остатка должно быть >= 0."

msgid "Increment"
msgstr "Прибавить"

msgid "Set"
msgstr "Установить"

msgid "Value to add/subtract (increment mode) or absolute value (set mode)."
msgstr "Значение для прибавления/вычитания (режим increment) или абсолютное значение (режим set)."

msgid "'increment' to add/subtract, 'set' to overwrite."
msgstr "'increment' — прибавить/вычесть, 'set' — перезаписать."

#, python-format
msgid "Insufficient stock. Current: %(current)d, adjustment: %(adjustment)d."
msgstr "Недостаточно остатка. Текущий: %(current)d, корректировка: %(adjustment)d."

# ── sales / models + serializers ────────────────────────────────────
msgid "Cash"
msgstr "Наличные"

msgid "Card"
msgstr "Карта"

msgid "Debt"
msgstr "Долг"

msgid "At least one item is required."
msgstr "Требуется минимум один товар."

msgid "Client is required for debt sales."
msgstr "Для продажи в долг требуется указать клиента."

msgid "Client not found."
msgstr "Клиент не найден."

#, python-format
msgid "Products not found: %(ids)s"
msgstr "Товары не найдены: %(ids)s"

#, python-format
msgid "Insufficient stock for '%(name)s'. Available: %(available)d, requested: %(requested)d."
msgstr "Недостаточно остатка для '%(name)s'. Доступно: %(available)d, запрошено: %(requested)d."
