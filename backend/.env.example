# =============================================================================
# Django
# =============================================================================
SECRET_KEY=change-me-to-a-long-random-string
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# =============================================================================
# Database (DATABASE_URL format)
# =============================================================================
# Local (without Docker): sqlite:///db.sqlite3
# Docker:                 postgres://anytech:anytech_dev_password@db:5432/anytech_erp
DATABASE_URL=sqlite:///db.sqlite3

# =============================================================================
# CORS
# =============================================================================
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# =============================================================================
# JWT (Simple JWT) — see config/settings/base.py SIMPLE_JWT
# =============================================================================
# Short access TTL → leaked token has minutes of usefulness, not a day.
# Refresh tokens rotate on each /token/refresh/ call (old one is blacklisted).
# JWT_ACCESS_TOKEN_LIFETIME_MINUTES=15
# JWT_REFRESH_TOKEN_LIFETIME_DAYS=7

# =============================================================================
# Celery
# =============================================================================
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# =============================================================================
# Docker Compose — PostgreSQL container
# =============================================================================
POSTGRES_DB=anytech_erp
POSTGRES_USER=anytech
POSTGRES_PASSWORD=anytech_dev_password

# =============================================================================
# Production only (uncomment when deploying)
# =============================================================================
# SECURE_SSL_REDIRECT=True
# CONN_MAX_AGE=60
# DJANGO_LOG_LEVEL=WARNING

# =============================================================================
# Sentry (production) — see config/settings/production.py
# =============================================================================
# Leave SENTRY_DSN empty in prod to disable Sentry entirely (no init runs).
# SENTRY_DSN=
# SENTRY_ENVIRONMENT=production
# SENTRY_RELEASE=
# Conservative defaults: errors yes, performance/profiling opt-in (0.0).
# SENTRY_TRACES_SAMPLE_RATE=0.0
# SENTRY_PROFILES_SAMPLE_RATE=0.0
# User has phone/email/passport — keep PII out of error payloads by default.
# SENTRY_SEND_DEFAULT_PII=False
